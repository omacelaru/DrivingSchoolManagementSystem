{
  "name": "driving-school-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:local-h2": "vite --mode local-h2",
    "dev:local-docker": "vite --mode local-docker",
    "dev:minikube": "vite --mode minikube",
    "dev:azure": "vite --mode azure",
    "build": "tsc -b && vite build",
    "build:local-h2": "tsc -b && vite build --mode local-h2",
    "build:local-docker": "tsc -b && vite build --mode local-docker",
    "build:minikube": "tsc -b && vite build --mode minikube",
    "build:azure": "tsc -b && vite build --mode azure",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
